# Copy this file to `.env` and fill in your values. `.env` is gitignored.

# Required — get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Optional overrides (defaults shown)
MODEL_NAME=claude-sonnet-4-20250514
TEMPERATURE=0.2
MAX_TOKENS=2048

# Comma-separated origins allowed by CORS. Add your prod domain when deploying.
CORS_ORIGINS=http://localhost:5173,http://localhost:8000

# Override only if you want to point at a different dataset directory.
# DATA_DIR=/abs/path/to/data
